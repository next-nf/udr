{erl_opts, [debug_info]}.

%% Compile the S6a Diameter dictionary with OTP's own dictionary compiler
%% (diameter_make) instead of the third-party rebar3_diameter_compiler plugin,
%% which does not build on OTP-29. All logic lives in gen_dict.sh because rebar3
%% runs hook commands via open_port/spawn, which does NOT interpret shell
%% operators (&&, ;, |, redirects) -- only a single program runs -- so the hook
%% must be one command. The script cd's to its own directory (via $0), so it is
%% independent of the hook's working directory.
%%
%% The compile pre_hook runs with CWD = this app dir; the eunit/ct pre_hooks run
%% with CWD = the project root. The differing relative paths below reflect that;
%% both resolve to the same script, which then self-locates.
{pre_hooks, [
    {compile, "sh gen_dict.sh"},
    {eunit, "sh apps/udr_diameter/gen_dict.sh"},
    {ct, "sh apps/udr_diameter/gen_dict.sh"}
]}.

%% Remove the generated dictionary on clean so stale artifacts never linger.
%% (rm with multiple operands is a single program, so no shell operators here.)
{post_hooks, [
    {clean, "rm -f src/diameter_3gpp_s6a.erl include/diameter_3gpp_s6a.hrl"}
]}.
