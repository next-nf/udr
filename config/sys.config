[
  {udr, []},
  {udr_db, [
    {backend, udr_db_mnesia},
    {backend_opts, #{storage => ram_copies}}
  ]},
  {udr_diameter, [
    {origin_host, "hss.epc.mnc001.mcc001.3gppnetwork.org"},
    {origin_realm, "epc.mnc001.mcc001.3gppnetwork.org"},
    {listen, [{tcp, {127,0,0,1}, 3868}]}
  ]},
  {udr_api, [{port, 8090}, {ip, {127,0,0,1}}]},
  {udr_sbi, [{port, 8080}, {ip, {127,0,0,1}}]},
  {opentelemetry, [
    {span_processor, batch},
    {traces_exporter, none},
    {resource, #{service => #{name => <<"hss-udr">>}}}
  ]},
  {opentelemetry_exporter, [
    {otlp_protocol, http_protobuf},
    {otlp_endpoint, "http://localhost:4318"}
  ]},
  {opentelemetry_experimental, [
    {readers, [
      %% OTLP push -- the native OTEL path. With an OTLP collector configured
      %% under opentelemetry_exporter (e.g. Grafana Alloy), metrics leave in
      %% native OTEL form and the collector applies the OTEL->Prometheus name
      %% transform. This is the preferred pipeline for the Grafana dashboard.
      #{module => otel_metric_reader, config => #{}},
      %% In-process OTEL Prometheus exporter -- udr_otel serves GET /metrics on
      %% :9464 (udr_otel metrics_port) from this named reader via a cowboy handler.
      %% add_total_suffix => true matches the standard OTEL->Prometheus convention
      %% (monotonic counters gain _total) so the series line up with the collector
      %% conversion the dashboard targets.
      #{module => otel_metric_reader_prometheus,
        config => #{server_name => udr_prometheus_reader,
                    add_total_suffix => true, add_scope_info => false}}
    ]}
  ]}
].
