%% Common Test sys.config (loaded via {ct_opts,[{sys_config,...}]} in rebar.config).
%%
%% The OpenTelemetry SDK is a process-global singleton: the FIRST suite in the CT
%% node to start `opentelemetry` fixes its exporter for the whole run (a later
%% application:set_env no-ops while the app is already running). With the default
%% sys.config exporter ('none'), a non-OTel suite that pulls in the SDK would
%% leave it exporting nowhere, so the OTel span-capture suites' spans never reach
%% the pid exporter.
%%
%% Make the pid exporter the SDK default for the entire test run instead. It DROPS
%% spans whenever no test has called udr_otel_pid_exporter:capture_to/1 (harmless
%% for non-OTel suites), and each OTel testcase's capture_to(self()) routes that
%% test's spans to it — independent of which suite started the SDK first.
[
 {udr_db, [
   {backend, udr_db_mnesia},
   {backend_opts, #{storage => ram_copies}}
 ]},
 {opentelemetry, [{span_processor, simple},
                  {traces_exporter, {udr_otel_pid_exporter, #{}}},
                  {resource, #{service => #{name => <<"hss-udr-test">>}}}]},
 {opentelemetry_experimental, [{readers, [#{module => otel_metric_reader, config => #{}}]}]}
].
