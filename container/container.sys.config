%% Container runtime configuration: same as config/sys.config, but binds the
%% diameter / SBI / provision listeners to 0.0.0.0 so they are reachable from
%% outside the container. Operators override this by mounting their own
%% sys.config (e.g. to switch udr_db to the mongo backend or wire up OTLP).
[
  {udr, []},
  {udr_db, [
    {backend, udr_db_mnesia},
    {backend_opts, #{storage => ram_copies}}
  ]},
  {udr_diameter, [
    {origin_host, "hss.epc.mnc001.mcc001.3gppnetwork.org"},
    {origin_realm, "epc.mnc001.mcc001.3gppnetwork.org"},
    {listen, [{tcp, {0,0,0,0}, 3868}]}
  ]},
  {udr_api, [{port, 8090}, {ip, {0,0,0,0}}]},
  {udr_sbi, [{port, 8080}, {ip, {0,0,0,0}}]},
  %% Bind the OTEL Prometheus /metrics endpoint to 0.0.0.0 so it is scrapable
  %% from outside the container (see opentelemetry_experimental readers below).
  {udr_otel, [{metrics_port, 9464}, {metrics_ip, {0,0,0,0}}]},
  {opentelemetry, [
    {span_processor, batch},
    {traces_exporter, none},
    {resource, #{service => #{name => <<"hss-udr">>}}}
  ]},
  {opentelemetry_exporter, [
    {otlp_protocol, http_protobuf},
    {otlp_endpoint, "http://localhost:4318"}
  ]},
  {opentelemetry_experimental, [
    {readers, [
      %% OTLP push (native OTEL) -- the preferred pipeline; a collector such as
      %% Grafana Alloy applies the OTEL->Prometheus name transform.
      #{module => otel_metric_reader, config => #{}},
      %% In-process OTEL Prometheus exporter -- udr_otel serves GET /metrics on
      %% :9464 from this named reader. add_total_suffix matches the standard
      %% OTEL->Prometheus convention the Grafana dashboard targets.
      #{module => otel_metric_reader_prometheus,
        config => #{server_name => udr_prometheus_reader,
                    add_total_suffix => true, add_scope_info => false}}
    ]}
  ]}
].
