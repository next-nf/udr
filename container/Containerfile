# ---- build stage: official Alpine Erlang/OTP-29 (rebar3 preinstalled) ------
FROM erlang:29-alpine AS build

# git:        fetch the `mongodb` and `opentelemetry_cowboy_h` git deps.
# build-base:  make + g++ for opentelemetry_process's C++ NIF, built by its
#              `make -C c_src` compile pre_hook (links -lstdc++; the runtime
#              stage already carries libstdc++/libgcc for it). The official image
#              ships rebar3 and OTP's `diameter` dict compiler (udr_diameter's
#              build-time pre_hook), but not a C toolchain.
RUN apk add --no-cache git build-base

WORKDIR /src
COPY . .

# Prod release (bundled ERTS) with the 0.0.0.0-binding container config.
RUN rebar3 as container release

# ---- runtime stage: minimal Alpine matching the builder's ABI --------------
# Pinned to the Alpine major.minor that erlang:29-alpine is built on (3.23) so
# libssl/libcrypto match the release's bundled ERTS (Erlang's crypto NIF links
# the system libcrypto at runtime).
FROM alpine:3.23 AS runtime

RUN apk add --no-cache openssl ncurses-libs libstdc++ libgcc ca-certificates \
 && adduser -D -h /opt/udr udr

WORKDIR /opt/udr
COPY --from=build --chown=udr:udr /src/_build/container/rel/udr ./

USER udr

# S6a diameter, Nudr (SBI) HTTP, provisioning HTTP, OTEL Prometheus /metrics
EXPOSE 3868 8080 8090 9464

ENTRYPOINT ["/opt/udr/bin/udr"]
CMD ["foreground"]
