{minimum_otp_vsn, "29"}.
{erl_opts, [debug_info]}.

%% The OpenTelemetry SDK is a process-global singleton; whichever suite starts it
%% first fixes its exporter for the whole CT node. Load config/ct.sys.config so
%% `rebar3 ct` configures the test pid exporter as the SDK default, regardless of
%% suite order (see config/ct.sys.config for the full rationale).
%% `udr_preload_cth` eagerly loads every running app's modules after each suite
%% starts its apps, so on-demand module loading off a cold CI disk doesn't surface
%% as in-test latency / timetrap flakiness (see the module doc for the rationale).
{ct_opts, [{sys_config, ["config/ct.sys.config"]},
           {ct_hooks, [udr_preload_cth, udr_db_reset_cth]}]}.
%% OpenTelemetry deps come from the next-nf forks, per the org observability
%% policy (nf-conventions: nf-architecture, reference/observability.md §2). The
%% core libraries are pinned to the `feature/prometheus-exporter-for-upstream`
%% branch of next-nf/opentelemetry-erlang, which carries the OTEL Prometheus
%% exporter (the next-nf addition being prepared for upstream) -- that is how a
%% `/metrics` surface is served from OTEL instruments, with no separate
%% Prometheus-exporter package. Pin by {branch, ...} until the exporter work
%% lands upstream and the forks can be retired (move to a tag / {ref, ...} then).
{deps, [
    {syn, "3.4.1"},
    {cowboy, "2.14.2"},
    {mongodb, {git, "https://github.com/comtihon/mongodb-erlang.git", {tag, "3.6.9"}}},

    %% OpenTelemetry core + metrics SDK/API (next-nf fork, Prometheus-exporter branch).
    %% Declare the API apps BEFORE the apps that depend on them: the fork apps carry
    %% inter-app version constraints (e.g. opentelemetry_experimental requires
    %% opentelemetry_api_experimental "~> 0.5.2", a version only the fork provides).
    %% Listing the providing app first registers it as a top-level git dep before the
    %% transitive constraint is resolved, so rebar3 satisfies it from the fork instead
    %% of falling back to hex (which only has 0.5.1).
    {opentelemetry_api,              {git_subdir, "https://github.com/next-nf/opentelemetry-erlang.git", {branch, "feature/prometheus-exporter-for-upstream"}, "apps/opentelemetry_api"}},
    {opentelemetry_api_experimental, {git_subdir, "https://github.com/next-nf/opentelemetry-erlang.git", {branch, "feature/prometheus-exporter-for-upstream"}, "apps/opentelemetry_api_experimental"}},
    {opentelemetry,                  {git_subdir, "https://github.com/next-nf/opentelemetry-erlang.git", {branch, "feature/prometheus-exporter-for-upstream"}, "apps/opentelemetry"}},
    {opentelemetry_experimental,     {git_subdir, "https://github.com/next-nf/opentelemetry-erlang.git", {branch, "feature/prometheus-exporter-for-upstream"}, "apps/opentelemetry_experimental"}},
    {opentelemetry_exporter,         {git_subdir, "https://github.com/next-nf/opentelemetry-erlang.git", {branch, "feature/prometheus-exporter-for-upstream"}, "apps/opentelemetry_exporter"}},

    %% HTTP instrumentation (next-nf fork) -- cowboy_h emits spans; the
    %% experimental_h handler adds opt-in HTTP server metrics (init/0 + metrics_cb).
    {opentelemetry_cowboy_h,              {git_subdir, "https://github.com/next-nf/opentelemetry_cowboy_h.git", {branch, "main"}, "apps/opentelemetry_cowboy_h"}},
    {opentelemetry_cowboy_experimental_h, {git_subdir, "https://github.com/next-nf/opentelemetry_cowboy_h.git", {branch, "main"}, "apps/opentelemetry_cowboy_experimental_h"}},

    %% BEAM/VM, Diameter and process instrumentation (next-nf contrib fork)
    {opentelemetry_beam,               {git_subdir, "https://github.com/next-nf/opentelemetry-erlang-contrib.git", {branch, "main"}, "instrumentation/opentelemetry_beam"}},
    {opentelemetry_diameter,           {git_subdir, "https://github.com/next-nf/opentelemetry-erlang-contrib.git", {branch, "main"}, "instrumentation/opentelemetry_diameter"}},
    {opentelemetry_process,            {git_subdir, "https://github.com/next-nf/opentelemetry-erlang-contrib.git", {branch, "main"}, "instrumentation/opentelemetry_process"}},
    {opentelemetry_process_propagator, {git_subdir, "https://github.com/next-nf/opentelemetry-erlang-contrib.git", {branch, "main"}, "propagators/opentelemetry_process_propagator"}}
]}.

{overrides, [
    %% The opentelemetry_exporter pulls in ts_chatterbox, which uses bare `catch`,
    %% deprecated in OTP-29 and an error under warnings_as_errors. Globally allow it.
    {add, [{erl_opts, [nowarn_deprecated_catch]}]},

    %% The next-nf OTEL fork apps declare their inter-app dependencies with hex-style
    %% version constraints (e.g. opentelemetry_experimental requires
    %% opentelemetry_api_experimental "~> 0.5.2"). We provide every OTEL app from the
    %% fork at the top level, but rebar3 otherwise tries to satisfy those transitive
    %% constraints from hex -- which silently pulls the hex build where hex still has
    %% the version, and hard-fails for api_experimental 0.5.2 (fork-only). Strip the
    %% inter-app constraints so rebar3 uses the top-level fork checkouts; each app's
    %% genuine external deps (grpcbox, tls_certificate_check) are kept. Build/run
    %% order is preserved by the apps' .app.src `applications` lists.
    {override, opentelemetry_api, [{deps, []}]},
    {override, opentelemetry_api_experimental, [{deps, []}]},
    {override, opentelemetry, [{deps, []}]},
    {override, opentelemetry_experimental, [{deps, []}]},
    {override, opentelemetry_exporter,
        [{deps, [{grpcbox, ">= 0.0.0"}, {tls_certificate_check, "~> 1.18"}]}]}
]}.

%% Include the Cowboy transitive deps in the dialyzer PLT so cowboy_req's
%% references to ranch types (ranch:ref/0, ranch_proxy_header:proxy_info/0)
%% resolve; otherwise dialyzer reports them as unknown types.
%% `mnesia` is used by `udr_db_mnesia` (database.md §3.1); without it dialyzer
%% reports ~17 "Unknown function mnesia:*" warnings.
%% `syn` is used by `udr_cluster` for per-key distributed locking.
{dialyzer, [{plt_extra_apps, [mnesia, syn,
                              cowboy, cowlib, ranch, mongodb, bson, poolboy, pbkdf2,
                              opentelemetry_api, opentelemetry,
                              opentelemetry_api_experimental, opentelemetry_experimental,
                              opentelemetry_cowboy_h, opentelemetry_cowboy_experimental_h,
                              opentelemetry_diameter, opentelemetry_beam,
                              opentelemetry_process]}]}.

%% Documentation: EEP-48 `-doc`/`-moduledoc` attributes rendered with ExDoc
%% (not edoc). Build with `rebar3 ex_doc`.
{project_plugins, [rebar3_ex_doc]}.

%% ExDoc reads the EEP-48 `Docs` chunk that the OTP-27+ compiler embeds in each
%% .beam (from the `-doc`/`-moduledoc` attributes). rebar3_ex_doc v0.3.0 also
%% runs an edoc "doc chunks" pass first, but ExDoc ignores its output (it reads
%% the beams directly). That edoc pass cannot parse the OTP-29 experimental
%% native-record syntax (`-record #eps_av{...}`) in udr_crypto and aborts with a
%% syntax_error, failing `rebar3 ex_doc`. edoc has no per-module exclude, so we
%% point its source scan at a suffix that matches no files: edoc then finds
%% nothing to parse, returns ok, and ExDoc supplies all docs from the beam
%% chunks. Drop this once the toolchain (edoc) supports native records.
{edoc_opts, [{source_suffix, ".no_edoc_src"}]}.

%% rebar3_ex_doc v0.3.0 writes each app's docs.config into that app's edoc
%% out_dir (`_build/docs/lib/<app>/doc`) before invoking ex_doc. Because the
%% edoc_opts above make edoc find no source files, edoc never creates that
%% directory, so write_config fails with enoent -- for EVERY umbrella app, not
%% just one. The plugin reads edoc_opts from the root config only (it ignores
%% per-app edoc_opts), so the neutralization above must stay global; we
%% therefore pre-create the doc out_dir for every app under apps/. The hook
%% runs from the project root before the edoc pass.
{pre_hooks, [
    {edoc, "sh -c 'for d in apps/*/; do mkdir -p _build/docs/lib/\"$(basename \"$d\")\"/doc; done'"}
]}.
{ex_doc, [
    {extras, ["README.md", "LICENSE"]},
    {main, "README.md"},
    {api_reference, true}
]}.
{hex, [{doc, #{provider => ex_doc}}]}.

{relx, [
    {release, {udr, "0.1.0"}, [
        udr_crypto,
        udr_db,
        %% Library backend app: load its code (so udr_db can select it at runtime
        %% via {udr_db, backend, udr_db_mongo}) but do NOT auto-start it — the mongo
        %% connection is started on demand by udr_db_sup's child_spec, and the
        %% `mongodb` driver app is started lazily by udr_db_mongo_conn. Keeps
        %% ETS-only deployments from booting the driver.
        {udr_db_mongo, load},
        udr_data,
        udr_cluster,
        udr_hss,
        %% OpenTelemetry SDK + instrumentation libraries start before the interface
        %% apps (udr_diameter/udr_api/udr_sbi) so the meter provider and every
        %% instrument exist before S6a/SBI/provisioning traffic is served. The
        %% interface apps now depend on these (HTTP handlers, udr_otel), so this
        %% order is also required for a consistent release boot.
        opentelemetry_exporter,
        opentelemetry,
        opentelemetry_experimental,
        opentelemetry_cowboy_h,
        opentelemetry_cowboy_experimental_h,
        opentelemetry_diameter,
        opentelemetry_beam,
        opentelemetry_process,
        opentelemetry_process_propagator,
        udr_otel,
        udr_diameter,
        udr_api,
        udr_sbi,
        udr,
        sasl
    ]},

    {mode, dev},

    %% automatically picked up if the files
    %% exist but can be set manually, which
    %% is required if the names aren't exactly
    %% sys.config and vm.args
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}

    %% the .src form of the configuration files do
    %% not require setting RELX_REPLACE_OS_VARS
    %% {sys_config_src, "./config/sys.config.src"},
    %% {vm_args_src, "./config/vm.args.src"}
]}.

{profiles, [
    {test, [
        {deps, [{proper, "1.5.0"}]}
    ]},
    %% prod is the default mode when prod
    %% profile is used, so does not have
    %% to be explicitly included like this
    {prod, [
        {relx, [
            {mode, prod}

            %% use minimal mode to exclude ERTS
            %% {mode, minimal}
        ]}
    ]},
    %% Container build: prod release (bundled ERTS) with the 0.0.0.0-binding
    %% container config. Built in the Containerfile via `rebar3 as container release`.
    {container, [
        {relx, [
            {mode, prod},
            {sys_config, "./container/container.sys.config"}
        ]}
    ]}
]}.
